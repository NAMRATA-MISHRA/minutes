# Copy to backend/.env (same directory as requirements.txt), or put .env at the repo root.
# Restart the server after changing this file.
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: also accepted as GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
UPLOAD_DIR=uploads
DATABASE_PATH=meetings.db
